# Sub2API gateway node environment.
# Copy to deploy/.env.node and fill secrets before starting docker compose.

# Image published by the test branch workflow.
SUB2API_IMAGE=ghcr.io/minikites8/sub2api:test-codex-quota-lease-demo

# Public listen port for the node API endpoint.
BIND_HOST=0.0.0.0
SERVER_PORT=8080
TZ=Asia/Shanghai

# Local node identity. The registration URL already includes the temporary key.
GATEWAY_QUOTA_LEASE_NODE_ID=sub2api-node-1
SUB2API_NODE_POOL=foreign
GATEWAY_QUOTA_LEASE_REGISTRATION_URL=https://control.example.com/api/v1/node-leases/nodes/register?registration_token=replace-me

# Local node PostgreSQL and Redis.
POSTGRES_USER=sub2api
POSTGRES_PASSWORD=change-me-node-postgres-password
POSTGRES_DB=sub2api
REDIS_PASSWORD=change-me-node-redis-password

# Optional local runtime secrets.
# JWT_SECRET can stay empty; the node creates and stores one in its local database.
# TOTP_ENCRYPTION_KEY can stay empty for gateway-node use.
#
# PowerShell:
# [Convert]::ToHexString([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32)).ToLower()
#
# Linux/macOS:
# openssl rand -hex 32
JWT_SECRET=
TOTP_ENCRYPTION_KEY=

# Lease behavior.
GATEWAY_QUOTA_LEASE_DEFAULT_GRANT_AMOUNT=1
GATEWAY_QUOTA_LEASE_LEASE_TTL_SECONDS=600
GATEWAY_QUOTA_LEASE_RECLAIM_GRACE_SECONDS=3600
GATEWAY_QUOTA_LEASE_REMOTE_TIMEOUT_SECONDS=15
GATEWAY_QUOTA_LEASE_PREFLIGHT_RESERVE_AMOUNT=0.000001
GATEWAY_QUOTA_LEASE_PREFETCH_LOW_WATERMARK_AMOUNT=0.2
GATEWAY_QUOTA_LEASE_PREFETCH_AVERAGE_WINDOW=5
GATEWAY_QUOTA_LEASE_PREFETCH_AVERAGE_MULTIPLIER=3
GATEWAY_QUOTA_LEASE_PREFETCH_DEBOUNCE_SECONDS=10

# Optional OAuth client secrets required by some account types.
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=
GEMINI_OAUTH_SCOPES=
GEMINI_QUOTA_POLICY=
GEMINI_CLI_OAUTH_CLIENT_SECRET=
ANTIGRAVITY_OAUTH_CLIENT_SECRET=
ANTIGRAVITY_USER_AGENT_VERSION=

# Optional network/proxy settings.
UPDATE_PROXY_URL=
SECURITY_URL_ALLOWLIST_ENABLED=false
SECURITY_URL_ALLOWLIST_ALLOW_INSECURE_HTTP=true
SECURITY_URL_ALLOWLIST_ALLOW_PRIVATE_HOSTS=true
SECURITY_URL_ALLOWLIST_UPSTREAM_HOSTS=
